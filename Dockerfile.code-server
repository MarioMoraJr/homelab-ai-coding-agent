FROM codercom/code-server:latest

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bubblewrap \
        build-essential \
        ca-certificates \
        curl \
        gh \
        jq \
        make \
        nodejs \
        npm \
        python3 \
        python3-pip \
        python3-venv \
        ripgrep \
        socat \
        tree \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex @google/gemini-cli

RUN mkdir -p /home/coder/.config/gh /home/coder/.gemini \
    && chown -R coder:coder /home/coder/.config /home/coder/.gemini

COPY scripts/agent-local /usr/local/bin/agent-local
COPY scripts/agent-gemini /usr/local/bin/agent-gemini
COPY scripts/agent-doctor /usr/local/bin/agent-doctor
RUN chmod +x /usr/local/bin/agent-local /usr/local/bin/agent-gemini /usr/local/bin/agent-doctor

USER coder

ENV PATH="/home/coder/.local/bin:${PATH}"
