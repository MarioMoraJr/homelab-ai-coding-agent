FROM codercom/code-server:latest

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bubblewrap \
        build-essential \
        ca-certificates \
        curl \
        jq \
        make \
        nodejs \
        npm \
        python3 \
        python3-pip \
        python3-venv \
        ripgrep \
        socat \
        tree \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @openai/codex

COPY scripts/agent-local /usr/local/bin/agent-local
RUN chmod +x /usr/local/bin/agent-local

USER coder

ENV PATH="/home/coder/.local/bin:${PATH}"
