FROM node:20-bookworm-slim

USER root

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        git \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN npm install -g @google/gemini-cli

WORKDIR /app

COPY mobile-agent-ui/package*.json ./
RUN npm install --omit=dev

COPY mobile-agent-ui/ ./

RUN mkdir -p /workspace /home/node/.gemini \
    && chown -R node:node /app /workspace /home/node/.gemini

USER node

ENV NODE_ENV=production
ENV PORT=8080
ENV WORKSPACE_ROOT=/workspace
ENV HOME=/home/node

EXPOSE 8080

CMD ["node", "server.js"]
