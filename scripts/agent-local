#!/usr/bin/env sh
set -eu

if [ "$#" -eq 0 ]; then
    echo "Usage: agent-local [--model MODEL] \"your coding task\"" >&2
    exit 2
fi

model="${OLLAMA_MODEL:-qwen2.5-coder:7b}"

if [ "${1:-}" = "--model" ]; then
    if [ "$#" -lt 3 ]; then
        echo "Usage: agent-local --model MODEL \"your coding task\"" >&2
        exit 2
    fi
    model="$2"
    shift 2
fi

prompt="$*"
workdir="$(pwd)"

git config --global --add safe.directory /home/coder/workspace >/dev/null 2>&1 || true

echo "agent-local"
echo "model: ${model}"
echo "workdir: ${workdir}"

if ! command -v codex >/dev/null 2>&1; then
    echo "error: codex CLI is not installed" >&2
    exit 1
fi

if ! wget -qO- http://127.0.0.1:11434/api/tags >/dev/null 2>&1; then
    echo "error: Ollama is not reachable at http://127.0.0.1:11434" >&2
    echo "hint: check that Ollama is running on Windows and the code-server container was started through Docker Compose" >&2
    exit 1
fi

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo
    echo "git status before run:"
    git status --short
else
    echo
    echo "warning: current directory is not inside a Git repo"
fi

echo
echo "running agent..."

codex exec \
    --oss \
    --local-provider ollama \
    -m "${model}" \
    --sandbox workspace-write \
    --skip-git-repo-check \
    "${prompt}"

echo
echo "agent finished"

if git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo
    echo "git status after run:"
    git status --short
    echo
    echo "review changes with: git diff"
fi
